# ========== 数据库 ==========
DB_HOST=postgres
DB_PORT=5432
DB_NAME=content_agent
DB_USER=agent
DB_PASSWORD=

# ========== Redis ==========
REDIS_HOST=redis
REDIS_PORT=6379

# ========== LLM（主） ==========
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.7

# ========== LLM（备选） ==========
MIMO_API_KEY=
MIMO_BASE_URL=https://api.mimo.ai/v1
MIMO_MODEL=mimo-v2.5-pro

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# ========== LLM 降级配置 ==========
LLM_MAX_RETRIES=3
LLM_FALLBACK_THRESHOLD=5
LLM_LATENCY_THRESHOLD=15
LLM_CACHE_TTL=3600

# ========== Embedding ==========
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# ========== 腾讯云 COS ==========
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=

# ========== JWT ==========
JWT_SECRET=
JWT_EXPIRE_HOURS=24

# ========== 应用 ==========
APP_ENV=development
APP_PORT=8000
